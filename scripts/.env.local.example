# Framer Configuration
# Get your API key from Framer project settings (Cmd+K → "open settings" → "API Keys")
FRAMER_PROJECT_URL=https://framer.com/projects/Website--your-project-id
FRAMER_API_KEY=your_framer_api_key_here

# Auto-publish settings (optional)
FRAMER_AUTO_PUBLISH=false  # Set to 'true' to automatically publish to preview
FRAMER_AUTO_DEPLOY=false   # Set to 'true' to automatically deploy to production

# Supabase Configuration (copy from your main .env file)
SUPABASE_URL=https://rnshobvpqegttrpaowxe.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
